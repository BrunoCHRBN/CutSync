{
  "expo": {
    "name": "CutSync Web",
    "slug": "cutsync-web",
    "version": "1.0.0",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": "production"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F0ECE0",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {}
    },
    "owner": "chernobrunos-organization"
  }
}
