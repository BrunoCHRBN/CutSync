{
  "name": "@cutsync/client",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "build:web": "expo export --platform web",
    "build:web:e2e": "expo export --platform web --clear",
    "eas:development": "npx eas-cli@latest build --platform android --profile development",
    "eas:preview": "npx eas-cli@latest build --platform android --profile preview",
    "eas:production": "npx eas-cli@latest build --platform android --profile production",
    "eas:builds": "npx eas-cli@latest build:list --platform android --limit 10",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "serve:test": "node scripts/serve-web-build.js"
  },
  "dependencies": {
    "@cutsync/brand": "*",
    "@cutsync/database": "*",
    "@cutsync/domain": "*",
    "@cutsync/validation": "*",
    "@supabase/supabase-js": "2.110.3",
    "expo": "~57.0.8",
    "expo-constants": "~57.0.7",
    "expo-dev-client": "~57.0.9",
    "expo-image": "~57.0.1",
    "expo-image-picker": "~57.0.6",
    "expo-linking": "~57.0.4",
    "expo-notifications": "~57.0.7",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-updates": "~57.0.10",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-url-polyfill": "4.0.0"
  }
}
