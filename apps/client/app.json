{
  "expo": {
    "name": "CutSync",
    "slug": "cutsync-client",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "cutsync",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ebed753a-2b13-4fa1-bb73-fc28270c2cec"
    },
    "ios": {
      "bundleIdentifier": "com.cutsync.client",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cutsync.client",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#294D3A"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F3EFE3",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "O CutSync acessa suas fotos somente para você escolher uma imagem de perfil.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#294D3A",
          "defaultChannel": "appointments"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "cutsync",
          "project": "cutsync-client",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ebed753a-2b13-4fa1-bb73-fc28270c2cec"
      }
    },
    "owner": "chernobruno"
  }
}
