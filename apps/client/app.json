{
  "expo": {
    "name": "CutSync",
    "slug": "cutsync-client",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "cutsync",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.cutsync.client",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cutsync.client",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "O CutSync acessa suas fotos somente para você escolher uma imagem de perfil.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#294D3A",
          "defaultChannel": "appointments"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ebed753a-2b13-4fa1-bb73-fc28270c2cec"
      }
    },
    "owner": "chernobruno"
  }
}
