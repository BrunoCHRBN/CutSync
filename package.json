{
  "name": "cutsync-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start:web",
    "start:web": "npm --workspace @cutsync/web run start",
    "start:client": "npm --workspace @cutsync/client run start",
    "start:business": "npm --workspace @cutsync/business run start",
    "start:control": "npm --workspace @cutsync/control run start",
    "web": "npm --workspace @cutsync/web run web",
    "android:client": "npm --workspace @cutsync/client run android",
    "ios:client": "npm --workspace @cutsync/client run ios",
    "android:business": "npm --workspace @cutsync/business run android",
    "ios:business": "npm --workspace @cutsync/business run ios",
    "eas:client:development": "npm --workspace @cutsync/client run eas:development",
    "eas:client:preview": "npm --workspace @cutsync/client run eas:preview",
    "eas:client:production": "npm --workspace @cutsync/client run eas:production",
    "eas:client:builds": "npm --workspace @cutsync/client run eas:builds",
    "build:web": "npm --workspace @cutsync/web run build:web",
    "serve:test": "npm run build:web && npm --workspace @cutsync/web run serve:test",
    "test:e2e": "playwright test",
    "test:e2e:client": "playwright test --config=playwright.client.config.ts",
    "test:e2e:update": "playwright test --update-snapshots",
    "typecheck:shared": "tsc --noEmit -p packages/tsconfig.json",
    "typecheck:web": "tsc --noEmit -p apps/web/tsconfig.json",
    "typecheck:client": "tsc --noEmit -p apps/client/tsconfig.json",
    "typecheck:business": "tsc --noEmit -p apps/business/tsconfig.json",
    "typecheck:control": "tsc --noEmit -p apps/control/tsconfig.json",
    "typecheck:new-apps": "npm run typecheck:shared && npm run typecheck:client && npm run typecheck:business",
    "lint": "npm run lint:web && npm run lint:client && npm run lint:business",
    "lint:web": "npm --workspace @cutsync/web run lint",
    "lint:client": "npm --workspace @cutsync/client run lint",
    "lint:business": "npm --workspace @cutsync/business run lint",
    "types:supabase": "bash scripts/generate-supabase-types.sh",
    "check:supabase-schema": "bash scripts/check-supabase-schema.sh",
    "tauri:dev": "npm --workspace @cutsync/web run tauri:dev",
    "tauri:build": "npm --workspace @cutsync/web run tauri:build"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "react-native-screens": "4.26.0"
  },
  "engines": {
    "node": "22.x"
  }
}
